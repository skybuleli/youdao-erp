{
  "name": "@youdao-erp/web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "check": "vue-tsc --noEmit && eslint . --ext .vue,.ts,.tsx",
    "test": "vitest",
    "preview": "vite preview",
    "deploy": "wrangler pages deploy dist",
    "android:init": "cap init YoudaoERP com.youdao.erp --web-dir dist",
    "android:sync": "cap sync android",
    "android:build": "cap copy android && cd android && ./gradlew assembleDebug",
    "android:open": "cap open android"
  },
  "dependencies": {
    "@capacitor-community/barcode-scanner": "^4.0.1",
    "@capacitor/android": "^6.2.0",
    "@capacitor/core": "^6.2.0",
    "@vicons/ionicons5": "^0.13.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "echarts": "^5.6.0",
    "lucide-vue-next": "^1.0.0",
    "pinia": "^2.3.0",
    "radix-vue": "^1.9.17",
    "tailwind-merge": "^3.5.0",
    "vue": "^3.5.0",
    "vue-echarts": "^7.0.0",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@tailwindcss/vite": "^4.2.4",
    "@vitejs/plugin-vue": "^5.2.0",
    "@youdao-erp/shared": "workspace:*",
    "autoprefixer": "^10.5.0",
    "eslint": "^9.0.0",
    "postcss": "^8.5.10",
    "tailwindcss": "^4.2.4",
    "typescript": "^5.4.0",
    "vite": "^6.0.0",
    "vitest": "^3.0.0",
    "vue-tsc": "^2.2.0"
  }
}
